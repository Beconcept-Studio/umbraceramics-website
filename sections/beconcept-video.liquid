{% liquid
  assign video = section.settings.video
  assign video_preview_image = section.settings.video_preview_image | default: video.preview_image
  assign video_autoplay = section.settings.video_autoplay
  assign video_muted = section.settings.video_muted
  assign video_loop = section.settings.video_loop
  assign caption = section.settings.caption
  # Quando il video è in autoplay, nascondiamo i controlli nativi e lasciamo
  # solo il pulsante play/pause custom. Se autoplay è spento, mostriamo i controlli.
  assign hide_native_controls = video_autoplay
  assign show_controls = true
  if hide_native_controls
    assign show_controls = false
  endif
  if video_autoplay
    assign video_muted = true
  endif
  assign alt = 'blocks.load_video' | t: description: video.alt | escape
  assign media_width_desktop = 100 | divided_by: 2 | append: 'vw'
  assign media_width_mobile = '100vw'
  assign sizes = '(min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '240, 352, 832, 1200, 1600, 1920, 2560, 3840'
%}

{% capture video_tag %}
  {{ video | video_tag: image_size: '2500x', autoplay: video_autoplay, loop: video_loop, muted: video_muted, controls: show_controls }}
{% endcapture %}

<div class="beconcept-video div--container-about">
  {% if video != blank %}
    <deferred-media
      class="beconcept-video__media"
      {% if video_autoplay %}
        autoplay
      {% endif %}
    >
      {% if video_preview_image != blank %}
        <button
          class="button deferred-media__poster-button button-unstyled"
          ref="deferredMediaPlayButton"
          aria-label="{{ alt }}"
          type="button"
          on:click="/showDeferredMedia"
          style="--video-aspect-ratio: {{ video.aspect_ratio }}"
        >
          {{
            video_preview_image
            | image_url: width: 3840
            | image_tag: widths: widths, sizes: sizes, loading: 'lazy', class: 'deferred-media__poster-image'
          }}
          <span class="deferred-media__poster-icon icon-play">
            <span class="visually-hidden">{{ 'accessibility.play_video' | t }}</span>
            {{- 'icon-play.svg' | inline_asset_content -}}
          </span>
        </button>
      {% endif %}

      {% if hide_native_controls %}
        <button
          class="button button-unstyled deferred-media__poster-button video-interaction-hint hidden"
          ref="toggleMediaButton"
          type="button"
          on:click="/toggleMedia"
        >
          <span class="deferred-media__poster-icon icon-play hidden">
            <span class="visually-hidden">{{ 'accessibility.play_video' | t }}</span>
            {{- 'icon-play.svg' | inline_asset_content -}}
          </span>
          <span class="deferred-media__poster-icon icon-pause hidden">
            <span class="visually-hidden">{{ 'accessibility.pause_video' | t }}</span>
            {{- 'icon-pause.svg' | inline_asset_content -}}
          </span>
        </button>
      {% endif %}
      <template>
        {{ video_tag }}
      </template>
      {% if video_autoplay or video_preview_image == blank %}
        {{ video_tag }}
      {% endif %}
    </deferred-media>
  {% else %}
    <div class="beconcept-video__placeholder">
      {{ 'hero-apparel-3' | placeholder_svg_tag }}
    </div>
  {% endif %}
  {% if caption != blank %}
    <p class="beconcept-video__caption">{{ caption }}</p>
  {% endif %}
</div>

{% render 'video-placeholder-styles' %}
{% render 'deferred-media-video-styles' %}

{% stylesheet %}
  .beconcept-video {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .beconcept-video__caption {
    margin: 0;
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.75;
  }

  .beconcept-video__placeholder {
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Beconcept Video",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "video_preview_image",
      "label": "Immagine di anteprima (opzionale)"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay",
      "info": "Se attivo, nasconde i controlli nativi, attiva muted e avvia il video automaticamente.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Muto",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "header",
      "content": "Didascalia"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Testo didascalia"
    }
  ],
  "presets": [
    {
      "name": "Beconcept Video"
    }
  ]
}
{% endschema %}
