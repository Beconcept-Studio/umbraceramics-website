<beconcept-signature class="relative">
  <div class="div--container-small flex items-center justify-center {% if section.settings.add_space_bottom %} space-bottom {% endif %} {% if section.settings.add_space_top %} space-top-less {% endif %}"">
    <div class="mx-auto">
      <span class="w-full block text-dark max-w-[80px] mx-auto">
        {{- 'alicia.svg' | inline_asset_content -}}
      </span>
    </div>
  </div>
</beconcept-signature>
{% schema %}
{
  "name": "Page Signature",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Settings"
    },
    {
      "type": "checkbox",
      "id": "add_space_top",
      "label": "Add padding top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "add_space_bottom",
      "label": "Add padding bottom",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Page Signature",
      "category": "Beconcept"
    }
  ]
}
{% endschema %}
