{% comment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap"
    rel="stylesheet"
  >
  <style>
    @font-face {
      font-family: "Amatic";
      src: url("{{ 'AmaticSC-Bold.woff2' | asset_url }}") format("woff2"),
           url("{{ 'AmaticSC-Bold.woff' | asset_url }}")  format("woff");
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "HelveticaNeue";
      src: url("{{ 'HelveticaNeue-Roman.woff2' | asset_url }}") format("woff2"),
           url("{{ 'HelveticaNeue-Roman.woff' | asset_url }}")  format("woff");
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "HelveticaNeue";
      src: url("{{ 'HelveticaNeue-Italic.woff2' | asset_url }}") format("woff2"),
           url("{{ 'HelveticaNeue-Italic.woff' | asset_url }}")  format("woff");
      font-weight: 400;
      font-style: italic;
      font-display: swap;
    }
    @font-face {
      font-family: "HelveticaNeue";
      src: url("{{ 'HelveticaNeue-Medium.woff2' | asset_url }}") format("woff2"),
           url("{{ 'HelveticaNeue-Medium.woff' | asset_url }}")  format("woff");
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "HelveticaNeue";
      src: url("{{ 'HelveticaNeue-MediumItalic.woff2' | asset_url }}") format("woff2"),
           url("{{ 'HelveticaNeue-MediumItalic.woff' | asset_url }}")  format("woff");
      font-weight: 500;
      font-style: italic;
      font-display: swap;
    }
  </style>
{% endcomment %}
